									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"jwtToken\", jsonData.token);",
									"    console.log(\"JWT Token set to environment variable 'jwtToken'\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
